#!/bin/bash

# Copyright (c) 2017 The Armbian Project https://www.armbian.com/
#
# This file is licensed under the terms of the GNU General Public
# License version 2. This program is licensed "as is" without any
# warranty of any kind, whether express or implied.

set -euo pipefail

if [[ ! -n ${1:-} ]]; then
	echo >&2 "Usage: $0 <overlay_source_file.dts>"
	exit -1
fi

if [[ $EUID -ne 0 ]]; then
	echo >&2 "This program must be run with superuser rights"
	exit -1
fi

if [[ ! -f $1 ]]; then
	echo >&2 "Can't open file $1. File does not exist?"
	exit -1
fi

if [[ $1 == *.dts ]]; then
	fname=$(basename "$1" .dts)
else
	echo >&2 "Overlay source file name should have the .dts extension"
	exit -1
fi

if [[ ! -f /etc/armbian-release ]]; then
	echo >&2 "Armbian is not installed properly. Missing armbian-release"
	exit -1
fi

. /etc/armbian-release

extlinux_conf="/boot/extlinux/extlinux.conf"
bootscript_overlay_mode="false"
rv110x_direct_env_mode="false"
explicit_armbian_env_overlay_mode="false"

get_armbian_env_value() {
	local key="$1"
	if [[ -f /boot/armbianEnv.txt ]]; then
		sed -n "s/^${key}=//p" /boot/armbianEnv.txt | head -n 1
	fi
}

boot_overlay_mode="${BOOT_OVERLAY_MODE:-}"
if [[ -z "${boot_overlay_mode}" ]]; then
	boot_overlay_mode="$(get_armbian_env_value boot_overlay_mode)"
fi

if [[ "${boot_overlay_mode}" == "armbianEnv" ]]; then
	explicit_armbian_env_overlay_mode="true"
fi

if [[ -f /boot/boot.cmd ]] && grep -q '^setenv overlay_error' /boot/boot.cmd; then
	bootscript_overlay_mode="true"
fi

if [[ -f /boot/armbianEnv.txt ]] && [[ ${LINUXFAMILY:-} == "rockchip-rv1106" || ${BOARDFAMILY:-} == "rockchip-rv1106" ]]; then
	rv110x_direct_env_mode="true"
fi

enable_extlinux_overlay() {
	local overlay_name="$1"
	local overlay_path="/boot/overlay-user/${overlay_name}.dtbo"
	local extlinux_pattern='^[[:space:]]*fdt(dir)?[[:space:]]'

	if grep -Eq '^[[:space:]]*fdtoverlays[[:space:]]' "${extlinux_conf}"; then
		if grep -Fq "${overlay_path}" "${extlinux_conf}"; then
			echo "Overlay ${overlay_name} was already added to ${extlinux_conf}, skipping"
			return 0
		fi
		sed -i "/^[[:space:]]*fdtoverlays[[:space:]]/ s|\$| ${overlay_path}|" "${extlinux_conf}"
	elif grep -Eq "${extlinux_pattern}" "${extlinux_conf}"; then
		sed -Ei "/${extlinux_pattern}/a\\  fdtoverlays ${overlay_path}" "${extlinux_conf}"
	else
		echo "  fdtoverlays ${overlay_path}" >> "${extlinux_conf}"
	fi
}

if [[ ${explicit_armbian_env_overlay_mode} == "true" ]] && [[ -f /boot/armbianEnv.txt ]]; then
	boot_mode="armbianEnv"
elif [[ ${bootscript_overlay_mode} == "true" || ${rv110x_direct_env_mode} == "true" ]] && [[ -f /boot/armbianEnv.txt ]]; then
	boot_mode="armbianEnv"
elif [[ -f "${extlinux_conf}" ]]; then
	boot_mode="extlinux"
elif [[ -f /boot/armbianEnv.txt ]]; then
	boot_mode="armbianEnv"
else
	echo >&2 "Armbian boot configuration is missing"
	exit -1
fi

if [[ ${boot_mode} == "armbianEnv" ]] && [[ ${explicit_armbian_env_overlay_mode} != "true" ]] && [[ ${bootscript_overlay_mode} != "true" ]] && [[ ${rv110x_direct_env_mode} != "true" ]]; then
	echo >&2 "Overlays are not supported on ${LINUXFAMILY^} based boards."
	exit -1
fi

if [[ -d /lib/modules/$(uname -r)/build/scripts/dtc ]]; then
	if [[ ! -x /lib/modules/$(uname -r)/build/scripts/dtc/dtc ]]; then
		echo >&2 "Error: kernel headers are not installed properly"
		echo >&2 "Can't find dtc that supports compiling overlays"
		echo >&2 "Please install the headers package for kernel $(uname -r)"
		exit -1
	else
		export PATH=/lib/modules/$(uname -r)/build/scripts/dtc/:$PATH
	fi
fi

if ! type dtc > /dev/null; then
	echo "Error: dtc not found in PATH"
	echo "Please try to install matching kernel headers"
	exit -1
fi

if ! grep -q 'symbols' <(dtc --help); then
	echo "Error: dtc does not support compiling overlays"
	exit -1
fi

if [[ ! -d /boot/overlay-user ]]; then
	mkdir -p /boot/overlay-user
fi

temp_dir=$(mktemp -d)
trap 'rm -rf "${temp_dir}"' EXIT

echo "Compiling the overlay"
dtc -@ -q -I dts -O dtb -o "${temp_dir}/${fname}.dtbo" "$1"

echo "Copying the compiled overlay file to /boot/overlay-user/"
cp "${temp_dir}/${fname}.dtbo" "/boot/overlay-user/${fname}.dtbo"

if [[ ${boot_mode} == "extlinux" ]]; then
	enable_extlinux_overlay "${fname}"
else
	if grep -q '^user_overlays=' /boot/armbianEnv.txt; then
		line=$(grep '^user_overlays=' /boot/armbianEnv.txt | cut -d'=' -f2)
		if grep -qE "(^|[[:space:]])${fname}([[:space:]]|$)" <<< "${line}"; then
			echo "Overlay ${fname} was already added to /boot/armbianEnv.txt, skipping"
		elif grep -q '^user_overlays=\s*$' /boot/armbianEnv.txt; then
			sed -i -e "s/^user_overlays=\s*$/user_overlays=${fname}/" /boot/armbianEnv.txt
		else
			sed -i -e "/^user_overlays=/ s/$/ ${fname}/" /boot/armbianEnv.txt
		fi
	else
		sed -i -e "\$auser_overlays=${fname}" /boot/armbianEnv.txt
	fi
fi

echo "Reboot is required to apply the changes"
